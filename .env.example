# Supabase project credentials (anon key only — safe to expose to browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only (used by scripts/seed-historical.ts and api/fx.ts)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# hCaptcha public site key (anti-bot on signup + forgot password)
# Get one at https://hcaptcha.com (free 1M req/month). Paste the SECRET key in
# Supabase Dashboard → Authentication → Settings → Captcha → hCaptcha.
# Leave empty in dev to skip captcha entirely.
VITE_HCAPTCHA_SITE_KEY=

# Salt Edge Open Banking credentials (Account Information Service).
# Create an Application in the Salt Edge dashboard, then paste App ID + Secret here.
# Same vars must be configured in Vercel for production. Server-only.
SALTEDGE_APP_ID=
SALTEDGE_APP_SECRET=
